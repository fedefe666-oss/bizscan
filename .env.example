# Clave API de Anthropic (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api06

# Contraseña para acceder al dashboard de análisis
DASHBOARD_PASSWORD=123456

# Puerto del servidor (Railway/Render lo asignan automáticamente)
PORT=3000

# Nombre de tu consultora/marca (opcional, aparece en el formulario)
BRAND_NAME=BizScan
